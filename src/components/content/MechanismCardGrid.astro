---
import { Image } from 'astro:assets';
import { renderGlossaryDescription } from '../../utils/renderGlossaryDescription';

interface MechanismCard {
  title: string;
  href: string;
  image: ImageMetadata;
  imageAlt: string;
  description: string;
}

interface Props {
  cards: MechanismCard[];
}

const { cards } = Astro.props;

---

<div class:list={['mechanism-card-grid', { 'is-single': cards.length === 1 }]}>
  {cards.map((card) => (
    <a href={card.href} class="mechanism-card" aria-label={`Open ${card.title}`}>
      <span class="mechanism-card-media">
        <Image src={card.image} alt={card.imageAlt} loading="lazy" data-no-lightbox />
      </span>
      <span class="mechanism-card-body">
        <span class="mechanism-card-meta">{card.href.startsWith('http') ? 'CAD reference' : 'In-depth guide'}</span>
        <span class="mechanism-card-title">{card.title}</span>
        <span class="mechanism-card-description" set:html={renderGlossaryDescription(card.description)} />
      </span>
    </a>
  ))}
</div>

<style>
  .mechanism-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 24rem), 1fr));
    grid-auto-rows: 1fr;
    align-items: stretch;
    gap: 1rem;
    margin-block: 1rem 2.25rem;
  }

  .mechanism-card-grid.is-single {
    max-width: 42rem;
  }

  .mechanism-card {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    margin: 0 !important;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-black);
    color: inherit;
    text-decoration: none;
    z-index: 0;
  }

  .mechanism-card:has(.glossary-term:hover) {
    z-index: 100;
    color: inherit;
    text-decoration: none;
    transition: border-color 160ms ease, transform 160ms ease, background-color 160ms ease;
  }

  .mechanism-card:hover,
  .mechanism-card:focus-visible {
    border-color: #2fbf5b;
    background: color-mix(in srgb, var(--sl-color-black) 92%, #2fbf5b);
    transform: translateY(-2px);
  }

  .mechanism-card:focus-visible {
    outline: 2px solid #2fbf5b;
    outline-offset: 3px;
  }

  .mechanism-card-media {
    overflow: hidden;
    border-radius: 7px 7px 0 0;
    height: clamp(14rem, 24vw, 20rem);
    padding: clamp(0.75rem, 2vw, 1.25rem);
    height: clamp(11rem, 16vw, 14rem);
    padding: clamp(0.85rem, 1.8vw, 1.15rem);
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-7);
    box-sizing: border-box;
  }

  .mechanism-card-media img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: contain;
    transition: transform 160ms ease;
  }

  .mechanism-card:hover img {
    transform: scale(1.02);
  }

  .mechanism-card-body {
    display: grid;
    align-content: start;
    gap: 0.55rem;
    padding: 1rem;
  }

  .mechanism-card-meta {
    display: block;
    margin: 0;
    color: #2fbf5b;
    font-size: var(--sl-text-xs);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .mechanism-card-title {
    display: block;
    margin: 0;
    color: var(--sl-color-white);
    font-size: var(--sl-text-xl);
    font-weight: 700;
    line-height: var(--sl-line-height-headings);
  }

  .mechanism-card-description {
    display: block;
    margin: 0;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }

  .mechanism-card-body :global(.glossary-term) {
    position: relative;
    cursor: help;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-decoration-color: var(--sl-color-gray-4);
    text-underline-offset: 0.2em;
  }

  .mechanism-card-body :global(.glossary-term)::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 100%;
    left: 50%;
    z-index: 200;
    width: max-content;
    max-width: 18rem;
    margin-bottom: 0.5rem;
    padding: 0.5rem 0.75rem;
    transform: translateX(-50%);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-1);
    font-size: var(--sl-text-sm);
    line-height: 1.4;
    opacity: 0;
    pointer-events: none;
    text-align: center;
    visibility: hidden;
  }

  .mechanism-card-body :global(.glossary-term):hover::after {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 44rem) {
    .mechanism-card-media {
      height: clamp(12rem, 58vw, 20rem);
    }
  }
</style>
