{
	"main": "@astrojs/cloudflare/entrypoints/server",
	"name": "frcdesign",
  "preview_urls": true,
  "compatibility_date": "2025-11-30",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  }
}
